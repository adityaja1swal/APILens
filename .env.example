# APILens Environment Configuration
# Copy this file to backend/.env and fill in values

# Anthropic Claude API Key (required for AI analysis)
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Server port
PORT=5000

# MongoDB connection (optional — app works without it, scan history won't persist)
MONGODB_URI=mongodb://localhost:27017/apilens

# Redis for job queue (optional)
REDIS_URL=redis://localhost:6379

# Mock mode — set to "true" to run without real API calls (for demos/testing)
MOCK_MODE=false

# Environment
NODE_ENV=development
